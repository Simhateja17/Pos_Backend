{
  "openapi": "3.1.0",
  "info": {
    "title": "Couture POS API",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "role": {
                "type": "string",
                "enum": [
                  "owner",
                  "manager",
                  "cashier"
                ]
              },
              "tenantId": {
                "type": "string",
                "format": "uuid"
              }
            },
            "required": [
              "id",
              "email",
              "role",
              "tenantId"
            ]
          },
          "session": {
            "type": "object",
            "properties": {
              "accessToken": {
                "type": "string"
              },
              "refreshToken": {
                "type": "string"
              }
            },
            "required": [
              "accessToken",
              "refreshToken"
            ]
          }
        },
        "required": [
          "user",
          "session"
        ]
      },
      "SignupRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "ownerName": {
            "type": "string",
            "minLength": 1
          },
          "businessName": {
            "type": "string",
            "minLength": 1
          },
          "addressLine1": {
            "type": "string",
            "minLength": 1
          },
          "addressLine2": {
            "type": "string"
          },
          "city": {
            "type": "string",
            "minLength": 1
          },
          "state": {
            "type": "string",
            "minLength": 1
          },
          "postalCode": {
            "type": "string",
            "minLength": 1
          },
          "country": {
            "type": "string",
            "default": "US"
          },
          "taxId": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password",
          "ownerName",
          "businessName",
          "addressLine1",
          "city",
          "state",
          "postalCode"
        ]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "Member": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "manager",
              "cashier"
            ]
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "role",
          "isActive",
          "createdAt"
        ]
      },
      "InviteMemberRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "manager",
              "cashier"
            ]
          }
        },
        "required": [
          "email",
          "name",
          "role"
        ]
      },
      "UpdateMemberRoleRequest": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "manager",
              "cashier"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "SetPinRequest": {
        "type": "object",
        "properties": {
          "pin": {
            "type": "string",
            "pattern": "^\\d{4}$"
          }
        },
        "required": [
          "pin"
        ]
      },
      "PinSwitchResponse": {
        "type": "object",
        "properties": {
          "operatorToken": {
            "type": "string"
          },
          "staff": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "owner",
                  "manager",
                  "cashier"
                ]
              }
            },
            "required": [
              "id",
              "role"
            ]
          }
        },
        "required": [
          "operatorToken",
          "staff"
        ]
      },
      "PinSwitchRequest": {
        "type": "object",
        "properties": {
          "staffId": {
            "type": "string"
          },
          "pin": {
            "type": "string"
          }
        },
        "required": [
          "staffId",
          "pin"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/auth/signup": {
      "post": {
        "description": "Real self-serve signup — creates a Supabase Auth user, a tenants row with the full business/tax profile, and an owner staff_members row.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Signup successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "409": {
            "description": "An account already exists with this email"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "description": "Email+password login via Supabase Auth. Derives role/tenantId from a server-side staff_members lookup.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid email or password"
          }
        }
      }
    },
    "/members": {
      "get": {
        "description": "List the caller's tenant's staff members. Requires manager or owner role.",
        "responses": {
          "200": {
            "description": "List of staff members",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Member"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions"
          }
        }
      }
    },
    "/members/invite": {
      "post": {
        "description": "Invite a new staff member (manager or cashier) into the caller's tenant. Owner-only.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InviteMemberRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Invite sent and staff row created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Member"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions"
          }
        }
      }
    },
    "/members/{memberId}/role": {
      "patch": {
        "description": "Change a staff member's role. Owner-only.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "memberId",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateMemberRoleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Role updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Member"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions"
          },
          "404": {
            "description": "Member not found"
          }
        }
      }
    },
    "/members/{memberId}": {
      "delete": {
        "description": "Soft-delete (deactivate) a staff member. Owner-only.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "memberId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Member deactivated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Member"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions"
          },
          "404": {
            "description": "Member not found"
          }
        }
      }
    },
    "/auth/set-pin": {
      "post": {
        "description": "An authenticated staff member (owner, manager, or a newly-activated invited manager/cashier) provisions/changes their own PIN. Requires a real Supabase session (authMiddleware) — never the PIN-switch mechanism. Always targets the caller's own staff_members row.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetPinRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PIN set",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "ok"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid PIN"
          },
          "404": {
            "description": "No staff record found for this account"
          }
        }
      }
    },
    "/terminal/pin/switch": {
      "post": {
        "description": "PIN-switch the acting operator on a shared terminal. Requires an existing authenticated session (authMiddleware); does not create a new Supabase Auth session — issues a short-lived signed operator token instead (D-09/D-10).",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PinSwitchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PIN-switch successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PinSwitchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Incorrect PIN, locked out, or unauthenticated"
          }
        }
      }
    }
  },
  "webhooks": {}
}