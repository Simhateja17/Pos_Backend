# Supabase project
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Prisma / Postgres connections
# Session-mode pooler (port 5432) — used only for `prisma db pull` / migrations tooling, NEVER for app runtime queries
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Transaction-mode pooler (port 6543) with the DEDICATED RESTRICTED ROLE (app_runtime, NOT postgres superuser)
# ?pgbouncer=true disables Prisma prepared statements — required for Supavisor transaction mode (RESEARCH.md Pitfall 3)
RLS_DATABASE_URL=postgresql://app_runtime:<restricted-role-password>@db.<project-ref>.supabase.co:6543/postgres?pgbouncer=true

PORT=4000

# Comma-separated allowlist of exact frontend origin(s) (scheme + host + port)
# permitted to call this API cross-origin (WR-06). Defaults to the local
# Next.js dev server origins if unset — see src/server.ts.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Frontend's accept-invite page — inviteUserByEmail's redirect target after
# the invitee clicks the email link (e.g. http://localhost:3000/accept-invite
# for local dev). The real page is built in 01-11/01-13.
INVITE_REDIRECT_URL=http://localhost:3000/accept-invite
